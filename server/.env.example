# Port
PORT=

# Tipo de despliegue
NODE_ENV=develop
# NODE_ENV=production

# URL del cliente Angular (para QR en tickets)
# En desarrollo se usa FRONTEND_URL_DEV o por defecto http://localhost:4200
FRONTEND_URL_DEV=http://localhost:4200
# En producción se usa FRONTEND_URL o APP_URL
# En producción: https://comercios.equinocciotechnology.com
APP_URL=https://comercios.equinocciotechnology.com

# Database
DATABASE_URL="mysql://db_user:db_password@db_host:db_port/db_name"

