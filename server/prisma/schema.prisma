generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                                   Int                        @id @default(autoincrement())
  username                             String                     @unique
  passwordHash                         String
  dni                                  String?                    @unique
  email                                String?
  nombre                               String?
  apellido                             String?
  rol                                  String                     @default("empleado")
  activo                               Boolean                    @default(true)
  creadoPorId                          Int?
  creadoPor                            User?                      @relation("UserCreatedBy", fields: [creadoPorId], references: [id], onDelete: SetNull)
  creados                              User[]                     @relation("UserCreatedBy")
  clientesCreados                      Cliente[]                  @relation("ClienteCreadoPor")
  clientesActualizados                 Cliente[]                  @relation("ClienteActualizadoPor")
  coloresCreados                       Color[]                    @relation("ColorCreadoPor")
  coloresActualizados                  Color[]                    @relation("ColorActualizadoPor")
  diagnosticosCreados                  Diagnostico[]              @relation("DiagnosticoCreadoPor")
  diagnosticosActualizados             Diagnostico[]              @relation("DiagnosticoActualizadoPor")
  ordenTrabajoTipoServicioActualizados OrdenTrabajoTipoServicio[] @relation("OrdenTrabajoTipoServicioActualizadoPor")
  ordenTrabajoTipoServicioProductosActualizados OrdenTrabajoTipoServicioProducto[] @relation("OrdenTrabajoTipoServicioProductoActualizadoPor")
  marcasCreadas                        Marca[]                    @relation("MarcaCreadoPor")
  marcasActualizadas                   Marca[]                    @relation("MarcaActualizadoPor")
  vehiculosCreados                     Vehiculo[]                 @relation("VehiculoCreadoPor")
  vehiculosActualizados                Vehiculo[]                 @relation("VehiculoActualizadoPor")
  tiposServicioCreados                 TipoServicio[]             @relation("TipoServicioCreadoPor")
  tiposServicioActualizados            TipoServicio[]             @relation("TipoServicioActualizadoPor")
  unidadesMedidaCreadas                UnidadMedida[]             @relation("UnidadMedidaCreadoPor")
  unidadesMedidaActualizadas           UnidadMedida[]             @relation("UnidadMedidaActualizadoPor")
  productosCreados                     Producto[]                 @relation("ProductoCreadoPor")
  productosActualizados                Producto[]                 @relation("ProductoActualizadoPor")
  etiquetasCreadas                     Etiqueta[]                 @relation("EtiquetaCreadoPor")
  etiquetasActualizadas                Etiqueta[]                 @relation("EtiquetaActualizadoPor")
  ordenesTrabajoAsignadas              OrdenTrabajo[]             @relation("OrdenTrabajoMecanico")
  ordenesTrabajoCreadas                OrdenTrabajo[]             @relation("OrdenTrabajoCreadoPor")
  ordenesTrabajoActualizadas           OrdenTrabajo[]             @relation("OrdenTrabajoActualizadoPor")
  createdAt                            DateTime                   @default(now())
  updatedAt                            DateTime                   @updatedAt
}

model Cliente {
  id                 Int            @id @default(autoincrement())
  razonSocial        String         @unique
  tipoIdentificacion String
  identificacion     String?        @unique
  telefono           String?
  domicilio          String?
  activo             Boolean        @default(true)
  creadoPorId        Int?
  creadoPor          User?          @relation("ClienteCreadoPor", fields: [creadoPorId], references: [id], onDelete: SetNull)
  actualizadoPorId   Int?
  actualizadoPor     User?          @relation("ClienteActualizadoPor", fields: [actualizadoPorId], references: [id], onDelete: SetNull)
  vehiculos          Vehiculo[]
  ordenesTrabajo     OrdenTrabajo[]
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
}

model Color {
  id               Int        @id @default(autoincrement())
  descripcion      String     @unique
  activo           Boolean    @default(true)
  creadoPorId      Int?
  creadoPor        User?      @relation("ColorCreadoPor", fields: [creadoPorId], references: [id], onDelete: SetNull)
  actualizadoPorId Int?
  actualizadoPor   User?      @relation("ColorActualizadoPor", fields: [actualizadoPorId], references: [id], onDelete: SetNull)
  vehiculos        Vehiculo[]
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

model Diagnostico {
  id               Int                        @id @default(autoincrement())
  descripcion      String                     @unique
  activo           Boolean                    @default(true)
  creadoPorId      Int?
  creadoPor        User?                      @relation("DiagnosticoCreadoPor", fields: [creadoPorId], references: [id], onDelete: SetNull)
  actualizadoPorId Int?
  actualizadoPor   User?                      @relation("DiagnosticoActualizadoPor", fields: [actualizadoPorId], references: [id], onDelete: SetNull)
  detalles         OrdenTrabajoTipoServicio[]
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
}

model Marca {
  id               Int        @id @default(autoincrement())
  marca            String
  modelo           String
  activo           Boolean    @default(true)
  creadoPorId      Int?
  creadoPor        User?      @relation("MarcaCreadoPor", fields: [creadoPorId], references: [id], onDelete: SetNull)
  actualizadoPorId Int?
  actualizadoPor   User?      @relation("MarcaActualizadoPor", fields: [actualizadoPorId], references: [id], onDelete: SetNull)
  vehiculos        Vehiculo[]
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@unique([marca, modelo])
}

model Vehiculo {
  id               Int            @id @default(autoincrement())
  marcaId          Int
  marca            Marca          @relation(fields: [marcaId], references: [id])
  colorId          Int
  color            Color          @relation(fields: [colorId], references: [id])
  anio             Int
  kilometraje      Int
  patente          String?        @unique
  clienteId        Int
  cliente          Cliente        @relation(fields: [clienteId], references: [id])
  activo           Boolean        @default(true)
  creadoPorId      Int?
  creadoPor        User?          @relation("VehiculoCreadoPor", fields: [creadoPorId], references: [id], onDelete: SetNull)
  actualizadoPorId Int?
  actualizadoPor   User?          @relation("VehiculoActualizadoPor", fields: [actualizadoPorId], references: [id], onDelete: SetNull)
  ordenesTrabajo   OrdenTrabajo[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model TipoServicio {
  id               Int                        @id @default(autoincrement())
  descripcion      String                     @unique
  activo           Boolean                    @default(true)
  creadoPorId      Int?
  creadoPor        User?                      @relation("TipoServicioCreadoPor", fields: [creadoPorId], references: [id], onDelete: SetNull)
  actualizadoPorId Int?
  actualizadoPor   User?                      @relation("TipoServicioActualizadoPor", fields: [actualizadoPorId], references: [id], onDelete: SetNull)
  detalles         OrdenTrabajoTipoServicio[]
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
}

model UnidadMedida {
  id               Int        @id @default(autoincrement())
  descripcion      String     @unique
  activo           Boolean    @default(true)
  creadoPorId      Int?
  creadoPor        User?      @relation("UnidadMedidaCreadoPor", fields: [creadoPorId], references: [id], onDelete: SetNull)
  actualizadoPorId Int?
  actualizadoPor   User?      @relation("UnidadMedidaActualizadoPor", fields: [actualizadoPorId], references: [id], onDelete: SetNull)
  productos        Producto[]
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

enum AlicuotaIva {
  IVA_21     @map("21")
  IVA_10_5   @map("10.5")
  IVA_EXENTO @map("exento")
}

model Producto {
  id                 Int          @id @default(autoincrement())
  descripcion        String       @unique
  codigo             String?
  unidadMedidaId     Int
  unidadMedida       UnidadMedida @relation(fields: [unidadMedidaId], references: [id])
  activo             Boolean      @default(true)
  cantidadInicial    Decimal      @db.Decimal(10, 2)
  alertaStock        Boolean      @default(false)
  cantidadMinima     Decimal      @db.Decimal(10, 2)
  precioCompra       Decimal?     @db.Decimal(10, 2)
  porcentajeGanancia Decimal?     @db.Decimal(5, 2)
  precioVenta        Decimal?     @db.Decimal(10, 2)
  precioMayorista    Decimal?     @db.Decimal(10, 2)
  alicuotaIva        AlicuotaIva
  creadoPorId        Int?
  creadoPor          User?        @relation("ProductoCreadoPor", fields: [creadoPorId], references: [id], onDelete: SetNull)
  actualizadoPorId   Int?
  actualizadoPor     User?        @relation("ProductoActualizadoPor", fields: [actualizadoPorId], references: [id], onDelete: SetNull)
  etiquetas          Etiqueta[]
  ordenTrabajoTipoServicioProductos OrdenTrabajoTipoServicioProducto[]
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}

model Etiqueta {
  id               Int        @id @default(autoincrement())
  descripcion      String     @unique
  activo           Boolean    @default(true)
  creadoPorId      Int?
  creadoPor        User?      @relation("EtiquetaCreadoPor", fields: [creadoPorId], references: [id], onDelete: SetNull)
  actualizadoPorId Int?
  actualizadoPor   User?      @relation("EtiquetaActualizadoPor", fields: [actualizadoPorId], references: [id], onDelete: SetNull)
  productos        Producto[]
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

enum Prioridad {
  normal
  alta
  urgente
}

enum Estado {
  pendiente
  en_proceso
  terminado
  cancelado
}

model OrdenTrabajo {
  id                Int                        @id @default(autoincrement())
  numero            String?                    @unique
  fechaIngreso      DateTime                   @default(now())
  kilometros        Int
  prioridad         Prioridad                  @default(normal)
  motivoIngreso     String                     @db.Text
  estado            Estado                     @default(pendiente)
  fechaFinalizacion DateTime?
  activo            Boolean                    @default(true)
  clienteId         Int
  cliente           Cliente                    @relation(fields: [clienteId], references: [id])
  vehiculoId        Int
  vehiculo          Vehiculo                   @relation(fields: [vehiculoId], references: [id])
  mecanicoId        Int
  mecanico          User                       @relation("OrdenTrabajoMecanico", fields: [mecanicoId], references: [id])
  detalles          OrdenTrabajoTipoServicio[]
  creadoPorId       Int?
  creadoPor         User?                      @relation("OrdenTrabajoCreadoPor", fields: [creadoPorId], references: [id], onDelete: SetNull)
  actualizadoPorId  Int?
  actualizadoPor    User?                      @relation("OrdenTrabajoActualizadoPor", fields: [actualizadoPorId], references: [id], onDelete: SetNull)
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
}

model OrdenTrabajoTipoServicio {
  id                  Int          @id @default(autoincrement())
  ordenTrabajoId      Int
  ordenTrabajo        OrdenTrabajo @relation(fields: [ordenTrabajoId], references: [id], onDelete: Cascade)
  tipoServicioId      Int
  tipoServicio        TipoServicio @relation(fields: [tipoServicioId], references: [id])
  estado              Estado       @default(pendiente)
  diagnosticoId       Int?
  diagnostico         Diagnostico? @relation(fields: [diagnosticoId], references: [id], onDelete: SetNull)
  trabajoRealizado    String?      @db.Text
  proximoServiceFecha DateTime?
  proximoServiceKm    Int?
  fechaFinalizacion   DateTime?
  actualizadoPorId    Int?
  actualizadoPor      User?        @relation("OrdenTrabajoTipoServicioActualizadoPor", fields: [actualizadoPorId], references: [id], onDelete: SetNull)
  productos           OrdenTrabajoTipoServicioProducto[]
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@unique([ordenTrabajoId, tipoServicioId])
}

model OrdenTrabajoTipoServicioProducto {
  id                         Int                      @id @default(autoincrement())
  ordenTrabajoTipoServicioId Int
  ordenTrabajoTipoServicio   OrdenTrabajoTipoServicio @relation(fields: [ordenTrabajoTipoServicioId], references: [id], onDelete: Cascade)
  productoId                 Int
  producto                   Producto                 @relation(fields: [productoId], references: [id])
  cantidad                   Decimal                  @db.Decimal(10, 2)
  precioUnitario             Decimal                  @db.Decimal(10, 2)
  precioTotal                Decimal                  @db.Decimal(10, 2)
  actualizadoPorId           Int?
  actualizadoPor             User?                    @relation("OrdenTrabajoTipoServicioProductoActualizadoPor", fields: [actualizadoPorId], references: [id], onDelete: SetNull)
  createdAt                  DateTime                 @default(now())
  updatedAt                  DateTime                 @updatedAt

  @@unique([ordenTrabajoTipoServicioId, productoId])
}
